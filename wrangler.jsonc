{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "app",
  "compatibility_date": "2026-06-21",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "NEXT_PUBLIC_API_URL": "https://portfolioos-backend-zdum.onrender.com"
  }
}